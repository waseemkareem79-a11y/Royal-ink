// ══════════════════════════════════════════════════════════
// EXPORT
// ══════════════════════════════════════════════════════════
function exportData() {
  if (DB.labels.length === 0) { toast('لا توجد بيانات للتصدير', 'error'); return; }

  const rows = [
    ['اسم الليبل','الشركة','الكود','القياس','الخط','الرف','نوع البليت',
     'اللون1','نسبة1','اللون2','نسبة2','اللون3','نسبة3','اللون4','نسبة4',
     'اللون5','نسبة5','اللون6','نسبة6','اللون7','نسبة7','اللون8','نسبة8'],
    ...DB.labels.map(l => {
      const base = [l.labelName,l.company,l.code,l.size,l.line,l.rack,l.pltType];
      for (let i=0;i<8;i++) {
        const c = l.colors[i];
        base.push(c ? c.inkCode : '', c ? (c.pct || '') : '');
      }
      return base;
    })
  ];

  const ws = XLSX.utils.aoa_to_sheet(rows);
  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'Labels');

  // Colors
  if (DB.colors.length) {
    const cws = XLSX.utils.aoa_to_sheet([['كود الحبر','اسم اللون'],...DB.colors.map(c=>[c.code,c.name])]);
    XLSX.utils.book_append_sheet(wb, cws, 'Colors');
  }

  XLSX.writeFile(wb, 'RoyalInk_Export.xlsx');
  toast('تم تصدير البيانات بنجاح!', 'success');
}

