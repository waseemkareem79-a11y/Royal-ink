<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Royal Ink — نظام إدارة الليبلات</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700;900&family=Space+Mono:wght@400;700&display=swap');

  :root {
    --ink-black:   #0D0D0F;
    --ink-deep:    #131318;
    --ink-panel:   #1A1A22;
    --ink-card:    #20202C;
    --ink-border:  #2C2C3E;
    --ink-gold:    #C9A84C;
    --ink-gold-lt: #E8C97A;
    --ink-gold-dk: #8B6F2E;
    --ink-silver:  #9898B0;
    --ink-dim:     #5A5A72;
    --ink-white:   #F0EEF8;
    --line-1: #4ECDC4;
    --line-2: #FF6B9D;
    --line-3: #7B68EE;
    --accent-green: #3DDC84;
    --accent-red:   #FF5252;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Cairo', sans-serif;
    background: var(--ink-black);
    color: var(--ink-white);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* ─── TOP BAR ─── */
  .topbar {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(13,13,15,0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--ink-border);
    display: flex; align-items: center; gap: 16px;
    padding: 0 24px; height: 60px;
  }
  .logo-mark {
    display: flex; align-items: center; gap: 10px; flex-shrink: 0;
  }
  .logo-icon {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--ink-gold), var(--ink-gold-dk));
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-family: 'Space Mono', monospace;
    font-size: 14px; font-weight: 700; color: var(--ink-black);
    letter-spacing: -1px;
  }
  .logo-text { font-size: 15px; font-weight: 700; color: var(--ink-white); }
  .logo-sub  { font-size: 10px; color: var(--ink-silver); font-weight: 300; }

  .topbar-search {
    flex: 1; max-width: 500px; position: relative;
  }
  .topbar-search input {
    width: 100%; padding: 8px 16px 8px 40px;
    background: var(--ink-panel); border: 1px solid var(--ink-border);
    border-radius: 8px; color: var(--ink-white);
    font-family: 'Cairo', sans-serif; font-size: 14px;
    outline: none; transition: border-color .2s;
  }
  .topbar-search input:focus { border-color: var(--ink-gold); }
  .topbar-search .search-icon {
    position: absolute; right: 12px; top: 50%; transform: translateY(-50%);
    color: var(--ink-silver); font-size: 14px; pointer-events: none;
  }

  .topbar-actions { margin-right: auto; display: flex; align-items: center; gap: 10px; }

  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 16px; border-radius: 7px; font-size: 13px;
    font-family: 'Cairo', sans-serif; font-weight: 600;
    cursor: pointer; border: none; transition: all .2s; white-space: nowrap;
  }
  .btn-primary {
    background: linear-gradient(135deg, var(--ink-gold), var(--ink-gold-dk));
    color: var(--ink-black);
  }
  .btn-primary:hover { filter: brightness(1.15); transform: translateY(-1px); }
  .btn-ghost {
    background: var(--ink-panel); border: 1px solid var(--ink-border);
    color: var(--ink-silver);
  }
  .btn-ghost:hover { border-color: var(--ink-gold); color: var(--ink-gold); }
  .btn-danger { background: var(--accent-red); color: #fff; }
  .btn-danger:hover { filter: brightness(1.1); }

  /* ─── LAYOUT ─── */
  .layout {
    display: flex; padding-top: 60px; min-height: 100vh;
  }

  /* ─── SIDEBAR ─── */
  .sidebar {
    width: 220px; flex-shrink: 0;
    background: var(--ink-deep);
    border-left: 1px solid var(--ink-border);
    padding: 20px 0;
    position: sticky; top: 60px;
    height: calc(100vh - 60px); overflow-y: auto;
  }
  .sidebar-section { margin-bottom: 24px; }
  .sidebar-label {
    font-size: 10px; font-weight: 700; letter-spacing: 1.5px;
    color: var(--ink-dim); padding: 0 18px 8px;
    text-transform: uppercase;
  }
  .sidebar-item {
    display: flex; align-items: center; gap: 10px;
    padding: 9px 18px; cursor: pointer;
    color: var(--ink-silver); font-size: 13px;
    transition: all .15s; border-right: 2px solid transparent;
  }
  .sidebar-item:hover { background: var(--ink-panel); color: var(--ink-white); }
  .sidebar-item.active {
    background: rgba(201,168,76,0.08);
    color: var(--ink-gold);
    border-right-color: var(--ink-gold);
  }
  .sidebar-item .dot {
    width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
  }
  .badge {
    margin-right: auto; background: var(--ink-border);
    color: var(--ink-silver); font-size: 10px; padding: 1px 6px;
    border-radius: 10px; font-weight: 600;
  }

  /* ─── MAIN CONTENT ─── */
  .main { flex: 1; padding: 28px; overflow: hidden; }

  /* ─── STAT CARDS ─── */
  .stats-row {
    display: grid; grid-template-columns: repeat(4,1fr); gap: 14px;
    margin-bottom: 24px;
  }
  .stat-card {
    background: var(--ink-card); border: 1px solid var(--ink-border);
    border-radius: 12px; padding: 18px 20px;
    display: flex; flex-direction: column; gap: 8px;
    position: relative; overflow: hidden;
  }
  .stat-card::before {
    content: ''; position: absolute; top: 0; right: 0;
    width: 3px; height: 100%; background: var(--accent-color, var(--ink-gold));
  }
  .stat-label { font-size: 11px; color: var(--ink-silver); font-weight: 600; letter-spacing: .5px; }
  .stat-value { font-size: 28px; font-weight: 900; color: var(--ink-white); line-height: 1; }
  .stat-sub { font-size: 11px; color: var(--ink-dim); }

  /* ─── FILTER BAR ─── */
  .filter-bar {
    display: flex; gap: 10px; align-items: center;
    margin-bottom: 18px; flex-wrap: wrap;
  }
  .filter-chip {
    padding: 6px 14px; border-radius: 20px;
    border: 1px solid var(--ink-border);
    background: var(--ink-card); color: var(--ink-silver);
    font-size: 12px; font-family: 'Cairo', sans-serif;
    cursor: pointer; transition: all .15s; white-space: nowrap;
  }
  .filter-chip:hover { border-color: var(--ink-gold); color: var(--ink-gold-lt); }
  .filter-chip.active {
    background: rgba(201,168,76,0.15); border-color: var(--ink-gold);
    color: var(--ink-gold-lt); font-weight: 700;
  }
  .filter-chip.line-1 { --chip-color: var(--line-1); }
  .filter-chip.line-2 { --chip-color: var(--line-2); }
  .filter-chip.line-3 { --chip-color: var(--line-3); }
  .filter-chip.line-1.active { background: rgba(78,205,196,0.12); border-color: var(--line-1); color: var(--line-1); }
  .filter-chip.line-2.active { background: rgba(255,107,157,0.12); border-color: var(--line-2); color: var(--line-2); }
  .filter-chip.line-3.active { background: rgba(123,104,238,0.12); border-color: var(--line-3); color: var(--line-3); }

  select.filter-select {
    padding: 6px 12px; border-radius: 8px;
    border: 1px solid var(--ink-border);
    background: var(--ink-card); color: var(--ink-silver);
    font-family: 'Cairo', sans-serif; font-size: 12px;
    outline: none; cursor: pointer;
  }
  select.filter-select:focus { border-color: var(--ink-gold); }

  /* ─── TABLE ─── */
  .table-wrap {
    background: var(--ink-card); border: 1px solid var(--ink-border);
    border-radius: 12px; overflow: hidden;
  }
  .table-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 14px 20px; border-bottom: 1px solid var(--ink-border);
  }
  .table-title { font-size: 14px; font-weight: 700; color: var(--ink-white); }
  .results-count { font-size: 12px; color: var(--ink-silver); }

  table { width: 100%; border-collapse: collapse; font-size: 12px; }
  thead th {
    background: var(--ink-panel); padding: 10px 12px;
    text-align: right; color: var(--ink-silver);
    font-size: 10px; font-weight: 700; letter-spacing: .5px;
    border-bottom: 1px solid var(--ink-border);
    white-space: nowrap; position: sticky; top: 0;
  }
  tbody tr {
    border-bottom: 1px solid rgba(44,44,62,0.5);
    transition: background .1s; cursor: pointer;
  }
  tbody tr:hover { background: rgba(201,168,76,0.04); }
  tbody tr:last-child { border-bottom: none; }
  td { padding: 10px 12px; color: var(--ink-white); vertical-align: middle; }
  td.muted { color: var(--ink-silver); font-size: 11px; }
  td.code {
    font-family: 'Space Mono', monospace; font-size: 11px;
    color: var(--ink-gold);
  }

  .line-badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 2px 8px; border-radius: 4px; font-size: 10px; font-weight: 700;
  }
  .line-badge.L1 { background: rgba(78,205,196,0.12); color: var(--line-1); }
  .line-badge.L2 { background: rgba(255,107,157,0.12); color: var(--line-2); }
  .line-badge.L3 { background: rgba(123,104,238,0.12); color: var(--line-3); }

  .color-pills { display: flex; gap: 4px; flex-wrap: wrap; }
  .color-pill {
    display: inline-flex; align-items: center; gap: 3px;
    padding: 2px 7px; border-radius: 3px; font-size: 10px;
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1);
    font-family: 'Space Mono', monospace;
  }
  .color-swatch {
    width: 8px; height: 8px; border-radius: 2px; flex-shrink: 0;
  }

  /* ─── EMPTY STATE ─── */
  .empty-state {
    padding: 60px 20px; text-align: center; color: var(--ink-dim);
  }
  .empty-icon { font-size: 40px; margin-bottom: 12px; opacity: .4; }
  .empty-text { font-size: 14px; }
  .empty-sub { font-size: 12px; margin-top: 6px; }

  /* ─── MODAL ─── */
  .modal-overlay {
    display: none; position: fixed; inset: 0; z-index: 200;
    background: rgba(0,0,0,0.75); backdrop-filter: blur(4px);
    align-items: center; justify-content: center;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: var(--ink-card); border: 1px solid var(--ink-border);
    border-radius: 16px; max-width: 700px; width: 92%;
    max-height: 85vh; overflow-y: auto; padding: 0;
    animation: slideUp .2s ease;
  }
  @keyframes slideUp {
    from { transform: translateY(20px); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }
  .modal-head {
    padding: 20px 24px; border-bottom: 1px solid var(--ink-border);
    display: flex; align-items: flex-start; justify-content: space-between; gap: 16px;
  }
  .modal-title { font-size: 18px; font-weight: 700; }
  .modal-subtitle { font-size: 12px; color: var(--ink-silver); margin-top: 3px; }
  .modal-close {
    background: none; border: none; color: var(--ink-silver);
    font-size: 20px; cursor: pointer; padding: 2px; line-height: 1;
    flex-shrink: 0;
  }
  .modal-close:hover { color: var(--ink-white); }
  .modal-body { padding: 20px 24px; }
  .modal-section-title {
    font-size: 11px; font-weight: 700; letter-spacing: 1px;
    color: var(--ink-gold); text-transform: uppercase; margin-bottom: 12px;
  }
  .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px; }
  .info-item { background: var(--ink-panel); border-radius: 8px; padding: 12px 14px; }
  .info-item-label { font-size: 10px; color: var(--ink-dim); font-weight: 600; letter-spacing: .5px; margin-bottom: 4px; }
  .info-item-value { font-size: 14px; color: var(--ink-white); font-weight: 600; }
  .info-item-value.mono { font-family: 'Space Mono', monospace; font-size: 12px; color: var(--ink-gold); }

  .colors-table { width: 100%; border-collapse: collapse; }
  .colors-table th {
    font-size: 10px; color: var(--ink-dim); font-weight: 700; letter-spacing: .5px;
    padding: 6px 8px; text-align: right; border-bottom: 1px solid var(--ink-border);
  }
  .colors-table td { padding: 8px 8px; font-size: 12px; border-bottom: 1px solid rgba(44,44,62,0.4); }
  .colors-table tr:last-child td { border-bottom: none; }
  .plate-num {
    display: inline-flex; width: 22px; height: 22px;
    align-items: center; justify-content: center;
    background: var(--ink-border); border-radius: 4px;
    font-size: 11px; font-weight: 700; color: var(--ink-silver);
    font-family: 'Space Mono', monospace;
  }

  /* ─── IMPORT PANEL ─── */
  .import-zone {
    border: 2px dashed var(--ink-border); border-radius: 12px;
    padding: 40px; text-align: center; cursor: pointer;
    transition: all .2s; position: relative;
  }
  .import-zone:hover, .import-zone.drag-over {
    border-color: var(--ink-gold); background: rgba(201,168,76,0.04);
  }
  .import-zone input[type=file] {
    position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;
  }
  .import-icon { font-size: 36px; margin-bottom: 12px; }
  .import-title { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
  .import-sub { font-size: 12px; color: var(--ink-silver); }

  .progress-bar-wrap {
    background: var(--ink-panel); border-radius: 4px; height: 6px;
    overflow: hidden; margin: 12px 0;
  }
  .progress-bar { height: 100%; background: var(--ink-gold); transition: width .3s; width: 0%; }

  /* ─── TABS ─── */
  .tabs { display: flex; gap: 2px; margin-bottom: 20px; }
  .tab {
    padding: 8px 18px; border-radius: 8px; cursor: pointer;
    font-size: 13px; font-weight: 600; color: var(--ink-silver);
    transition: all .15s; border: 1px solid transparent;
  }
  .tab.active {
    background: rgba(201,168,76,0.1); border-color: var(--ink-gold);
    color: var(--ink-gold);
  }
  .tab:hover:not(.active) { color: var(--ink-white); }

  .tab-content { display: none; }
  .tab-content.active { display: block; }

  /* ─── INK MIX TABLE ─── */
  .pct-bar {
    display: flex; align-items: center; gap: 8px; margin-top: 2px;
  }
  .pct-fill {
    height: 4px; border-radius: 2px; background: var(--ink-gold);
    flex-shrink: 0;
  }
  .pct-label { font-size: 10px; color: var(--ink-dim); }

  /* ─── TOAST ─── */
  .toast-container {
    position: fixed; bottom: 24px; left: 24px;
    display: flex; flex-direction: column; gap: 8px; z-index: 999;
  }
  .toast {
    background: var(--ink-panel); border: 1px solid var(--ink-border);
    border-radius: 10px; padding: 12px 18px; font-size: 13px;
    display: flex; align-items: center; gap: 10px;
    animation: toastIn .25s ease; max-width: 320px;
  }
  @keyframes toastIn {
    from { transform: translateX(-20px); opacity: 0; }
    to   { transform: translateX(0);     opacity: 1; }
  }
  .toast.success { border-color: var(--accent-green); color: var(--accent-green); }
  .toast.error   { border-color: var(--accent-red);   color: var(--accent-red); }
  .toast.info    { border-color: var(--ink-gold);     color: var(--ink-gold); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 768px) {
    .sidebar { display: none; }
    .stats-row { grid-template-columns: 1fr 1fr; }
    .topbar-search { max-width: 200px; }
  }

  /* ─── SCROLLBAR ─── */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--ink-border); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--ink-dim); }

  /* header glow */
  .glow-gold { text-shadow: 0 0 24px rgba(201,168,76,0.5); }

  .section-hidden { display: none; }

  /* ─── INK COLORS PAGE ─── */
  .colors-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 12px;
  }
  .color-card {
    background: var(--ink-card); border: 1px solid var(--ink-border);
    border-radius: 10px; overflow: hidden; cursor: pointer;
    transition: border-color .15s;
  }
  .color-card:hover { border-color: var(--ink-gold); }
  .color-preview { height: 56px; }
  .color-card-body { padding: 10px 12px; }
  .color-card-code { font-family: 'Space Mono', monospace; font-size: 11px; color: var(--ink-gold); }
  .color-card-name { font-size: 13px; font-weight: 600; margin-top: 2px; }

  /* ─── LOADING SPINNER ─── */
  .spinner {
    width: 32px; height: 32px;
    border: 3px solid var(--ink-border);
    border-top-color: var(--ink-gold);
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    margin: 0 auto;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>
</head>
<body>

<!-- ───────── TOPBAR ───────── -->
<header class="topbar">
  <div class="logo-mark">
    <div class="logo-icon">RI</div>
    <div>
      <div class="logo-text">Royal Ink</div>
      <div class="logo-sub">نظام إدارة الإنتاج</div>
    </div>
  </div>

  <div class="topbar-search">
    <span class="search-icon">⌕</span>
    <input type="text" id="globalSearch" placeholder="ابحث عن ليبل، شركة، كود..." oninput="onSearch()">
  </div>

  <div class="topbar-actions">
    <button class="btn btn-ghost" onclick="showSection('import')">⬆ استيراد Excel</button>
    <button class="btn btn-primary" onclick="exportData()">⬇ تصدير</button>
  </div>
</header>

<!-- ───────── LAYOUT ───────── -->
<div class="layout">

  <!-- SIDEBAR -->
  <nav class="sidebar">
    <div class="sidebar-section">
      <div class="sidebar-label">القوائم الرئيسية</div>
      <div class="sidebar-item active" onclick="showSection('labels')" id="nav-labels">
        <div class="dot" style="background:var(--ink-gold)"></div>
        الليبلات
        <span class="badge" id="badge-labels">—</span>
      </div>
      <div class="sidebar-item" onclick="showSection('colors')" id="nav-colors">
        <div class="dot" style="background:var(--line-1)"></div>
        أحبار الألوان
        <span class="badge" id="badge-colors">—</span>
      </div>
      <div class="sidebar-item" onclick="showSection('inkmix')" id="nav-inkmix">
        <div class="dot" style="background:var(--line-2)"></div>
        تركيبة الأحبار
        <span class="badge" id="badge-inkmix">—</span>
      </div>
    </div>

    <div class="sidebar-section">
      <div class="sidebar-label">التصفية السريعة</div>
      <div class="sidebar-item" onclick="filterLine('ALL')" id="filter-ALL">
        <div class="dot" style="background:var(--ink-dim)"></div>
        كل الخطوط
      </div>
      <div class="sidebar-item" onclick="filterLine('LINE-1')" id="filter-LINE-1">
        <div class="dot" style="background:var(--line-1)"></div>
        LINE-1
      </div>
      <div class="sidebar-item" onclick="filterLine('LINE-2')" id="filter-LINE-2">
        <div class="dot" style="background:var(--line-2)"></div>
        LINE-2
      </div>
      <div class="sidebar-item" onclick="filterLine('LINE-3')" id="filter-LINE-3">
        <div class="dot" style="background:var(--line-3)"></div>
        LINE-3
      </div>
    </div>

    <div class="sidebar-section">
      <div class="sidebar-label">الإجراءات</div>
      <div class="sidebar-item" onclick="showSection('import')">
        <div class="dot" style="background:var(--accent-green)"></div>
        مزامنة / استيراد
      </div>
    </div>
  </nav>

  <!-- MAIN -->
  <main class="main">

    <!-- ─── LABELS SECTION ─── -->
    <section id="section-labels">
      <div class="stats-row" id="statsRow"></div>

      <!-- Filter Bar -->
      <div class="filter-bar">
        <span style="font-size:12px;color:var(--ink-silver);font-weight:600;">الخط:</span>
        <span class="filter-chip active" onclick="filterLine('ALL')" id="chip-ALL">الكل</span>
        <span class="filter-chip line-1" onclick="filterLine('LINE-1')" id="chip-LINE-1">LINE-1</span>
        <span class="filter-chip line-2" onclick="filterLine('LINE-2')" id="chip-LINE-2">LINE-2</span>
        <span class="filter-chip line-3" onclick="filterLine('LINE-3')" id="chip-LINE-3">LINE-3</span>

        <span style="font-size:12px;color:var(--ink-silver);font-weight:600;margin-right:8px;">القياس:</span>
        <select class="filter-select" id="sizeFilter" onchange="applyFilters()">
          <option value="">كل القياسات</option>
          <option>185-ML</option><option>250-ML</option>
          <option>300-ML</option><option>330-ML</option>
        </select>

        <span style="font-size:12px;color:var(--ink-silver);font-weight:600;margin-right:8px;">الشركة:</span>
        <select class="filter-select" id="companyFilter" onchange="applyFilters()">
          <option value="">كل الشركات</option>
        </select>
      </div>

      <div class="table-wrap">
        <div class="table-header">
          <span class="table-title">جدول الليبلات</span>
          <span class="results-count" id="resultsCount">—</span>
        </div>
        <div style="overflow-x:auto;">
          <table>
            <thead>
              <tr>
                <th>#</th>
                <th>اسم الليبل</th>
                <th>الشركة</th>
                <th>الكود</th>
                <th>القياس</th>
                <th>الخط</th>
