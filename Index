  const colorLookup = {};
  DB.colors.forEach(c => colorLookup[c.code] = c.name);

  const win = window.open('', '_blank');
  win.document.write(`<!DOCTYPE html><html lang="ar" dir="rtl">
  <head><meta charset="UTF-8"><title>${label.labelName}</title>
  <style>
    body{font-family:Arial,sans-serif;padding:20px;direction:rtl}
    h2{margin:0 0 4px}
    .meta{color:#666;font-size:13px;margin-bottom:16px}
    table{border-collapse:collapse;width:100%}
    th,td{border:1px solid #ccc;padding:8px 10px;text-align:right;font-size:12px}
    th{background:#f5f5f5;font-weight:700}
    .hdr{display:flex;justify-content:space-between;margin-bottom:12px}
    .hdr-box{border:1px solid #ccc;padding:8px 14px;border-radius:4px;font-size:12px}
    @media print{body{padding:10px}}
  </style></head><body>
  <div class="hdr">
    <div><h2>${label.labelName}</h2><div class="meta">${label.company} — ${label.code}</div></div>
    <div style="text-align:left">
      <div class="hdr-box">الخط: <strong>${label.line}</strong></div>
      <div class="hdr-box" style="margin-top:4px">الرف: <strong>${label.rack}</strong></div>
    </div>
  </div>
  <table>
    <thead><tr><th>#</th><th>كود الحبر</th><th>اسم اللون</th><th>النسبة %</th><th>الكمية</th><th>رقم البليت</th><th>ملاحظات</th></tr></thead>
    <tbody>
    ${label.colors.map((c,i)=>`<tr>
      <td>${i+1}</td>
      <td>${c.inkCode}</td>
      <td>${colorLookup[c.inkCode]||'—'}</td>
      <td>${c.pct!==undefined&&c.pct!==''?c.pct+'%':'—'}</td>
      <td>${c.qty!==undefined&&c.qty!==''?c.qty:'—'}</td>
      <td>${c.plate||'—'}</td>
      <td>${c.notes||''}</td>
    </tr>`).join('')}
    </tbody>
  </table>
  <div style="margin-top:12px;font-size:11px;color:#999">
    القياس: ${label.size} &nbsp;|&nbsp; نوع البليت: ${label.pltType} &nbsp;|&nbsp; طُبع: ${new Date().toLocaleDateString('ar-IQ')}
  </div>
  <script>window.onload=()=>{window.print();}<\/script>
  </body></html>`);
  win.document.close();
}

